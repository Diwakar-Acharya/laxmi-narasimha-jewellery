---
import { businessConfig } from '../data/config';
---

<section id="location" class="py-24 bg-charcoal-900 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      
      <!-- Contact details -->
      <div class="lg:col-span-5 space-y-8">
        <div class="space-y-4">
          <span class="text-xs font-semibold tracking-[0.2em] text-gold-400 uppercase">Find Us</span>
          <h2 class="text-3xl sm:text-4xl font-serif font-bold text-white">Visit Our Showroom</h2>
          <div class="h-1 w-20 bg-gold-400 rounded-full"></div>
        </div>

        <p class="text-charcoal-300 font-sans text-sm sm:text-base leading-relaxed">
          Step into a world of gold and diamond brilliance. Visit our showroom in Kharagpur Gate Bazar to inspect hallmarked collections or discuss bespoke custom orders.
        </p>

        <!-- Structured Contact info -->
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center text-gold-400 shrink-0">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h4 class="font-serif font-bold text-white mb-1">Our Location</h4>
              <p class="text-sm text-charcoal-400 leading-relaxed">
                {businessConfig.address}
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center text-gold-400 shrink-0">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h4 class="font-serif font-bold text-white mb-1">Phone Number</h4>
              <p class="text-sm text-charcoal-400">
                <a href={`tel:${businessConfig.phone}`} class="hover:text-gold-400 transition-colors font-medium">{businessConfig.phoneFormatted}</a>
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center text-gold-400 shrink-0">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h4 class="font-serif font-bold text-white mb-1">Showroom Hours</h4>
              <p class="text-sm text-charcoal-400">
                {businessConfig.openingHours}
              </p>
            </div>
          </div>
        </div>

        <!-- Quick Contacts row -->
        <div class="flex flex-wrap gap-4 pt-4">
          <a href={`tel:${businessConfig.phone}`} class="inline-flex items-center gap-2 px-5 py-3 rounded-full border border-charcoal-800 text-white hover:text-gold-400 text-xs font-semibold uppercase tracking-wider transition-colors cursor-pointer">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            Call Now
          </a>
          <a href={businessConfig.whatsappLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-[#25D366] hover:bg-[#128C7E] text-white text-xs font-semibold uppercase tracking-wider transition-colors cursor-pointer">
            <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.458L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.528 2.025 14.077 1 11.83 1 6.55 1 2.227 5.275 2.224 10.556c0 1.692.459 3.344 1.332 4.79l-.994 3.63 3.79-.993c1.42.846 2.972 1.291 4.5 1.291z" />
            </svg>
            WhatsApp
          </a>
        </div>
      </div>

      <!-- Lazy-loaded Map Card -->
      <div class="lg:col-span-7">
        <div id="map-container" class="relative rounded-3xl overflow-hidden glass-panel border border-gold-400/10 h-96 sm:h-[450px] shadow-gold-glow-lg flex items-center justify-center bg-charcoal-950">
          
          <!-- Privacy Placeholder Overlay -->
          <div id="map-placeholder" class="absolute inset-0 flex flex-col items-center justify-center text-center p-8 z-10 bg-charcoal-950/95 space-y-4 transition-opacity duration-300">
            <div class="w-16 h-16 rounded-full bg-gold-400/10 border border-gold-400/20 flex items-center justify-center text-gold-400">
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
            </div>
            <div class="space-y-2">
              <h3 class="font-serif text-lg font-bold text-white">Interactive Google Map</h3>
              <p class="text-xs text-charcoal-400 max-w-sm">
                Loading the map will send requests to Google Maps.
              </p>
            </div>
            <button id="load-map-btn" type="button" class="px-5 py-2.5 rounded-full bg-gold-400 hover:bg-gold-300 text-charcoal-950 text-xs font-semibold uppercase tracking-wider transition-colors cursor-pointer">
              Load Interactive Map
            </button>
          </div>

          <!-- The iframe placeholder (injected via JS after consent) -->
          <div id="map-iframe-target" class="w-full h-full"></div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<script>
  import { businessConfig } from '../data/config';

  const loadMapBtn = document.getElementById('load-map-btn');
  const mapPlaceholder = document.getElementById('map-placeholder');
  const mapIframeTarget = document.getElementById('map-iframe-target');

  const loadMap = () => {
    if (mapIframeTarget && mapPlaceholder) {
      mapPlaceholder.classList.add('opacity-0');
      setTimeout(() => {
        mapPlaceholder.classList.add('hidden');
      }, 300);

      const iframe = document.createElement('iframe');
      iframe.src = businessConfig.mapsEmbedUrl;
      iframe.width = '100%';
      iframe.height = '100%';
      iframe.style.border = '0';
      iframe.title = 'Sri Laxmi Narasimha Jewellery Location Map';
      iframe.allowFullscreen = false;
      iframe.loading = 'lazy';
      iframe.referrerPolicy = 'no-referrer-when-downgrade';
      
      mapIframeTarget.appendChild(iframe);
    }
  };

  loadMapBtn?.addEventListener('click', loadMap);

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Keeping it behind click to honor privacy rules strictly
      }
    });
  });

  const mapContainer = document.getElementById('map-container');
  if (mapContainer) {
    observer.observe(mapContainer);
  }
</script>
