---
const galleryItems = [
  {
    id: 1,
    title: "Antique Royal Choker",
    category: "Heritage Gold",
    desc: "22K hallmarked antique finish gold choker adorned with intricate filigree and delicate ruby-emerald bead drops.",
    image: "/laxmi-narasimha-jewellery/assets/bridal_necklace.png"
  },
  {
    id: 2,
    title: "Solitaire Diamond Ring",
    category: "Brilliant Diamonds",
    desc: "Round brilliant cut solitaire diamond claw-set in an elegant 18K white gold band.",
    image: "/laxmi-narasimha-jewellery/assets/diamond_ring.png"
  },
  {
    id: 3,
    title: "Heritage Temple Jhumkas",
    category: "Heritage Gold",
    desc: "Intricately carved Laxmi motifs in temple gold hanging earrings with ruby accents and delicate pearls.",
    image: "/laxmi-narasimha-jewellery/assets/gold_earrings.png"
  },
  {
    id: 4,
    title: "Royal Kundan Kada",
    category: "Bridal Couture",
    desc: "Heavy gold bangle encrusted with glass kundan stones and detailed red-green meenakari artwork on the inner rim.",
    image: "/laxmi-narasimha-jewellery/assets/gold_bangle.png"
  },
  {
    id: 5,
    title: "Traditional Gold Payals",
    category: "Heritage Gold",
    desc: "Exquisite traditional gold payals (anklets) featuring detailed carvings, ruby clusters, and musical bells.",
    image: "/laxmi-narasimha-jewellery/assets/gold_payals.png"
  },
  {
    id: 6,
    title: "Heritage Emerald Pendant",
    category: "Bridal Couture",
    desc: "Detailed royal necklace pendant adorned with central drop emerald and surrounding brilliant-cut diamonds.",
    image: "/laxmi-narasimha-jewellery/assets/bridal_necklace.png"
  }
];
---

<section id="gallery" class="py-24 bg-charcoal-50 dark:bg-charcoal-900 transition-colors duration-300 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-end gap-6 mb-16">
      <div class="space-y-4">
        <span class="text-xs font-semibold tracking-[0.2em] text-gold-500 uppercase">Interactive Showroom</span>
        <h2 class="text-3xl sm:text-4xl font-serif font-bold">Artisanal Gallery</h2>
        <div class="h-1 w-20 bg-gold-400 rounded-full"></div>
      </div>
      <p class="text-sm text-charcoal-600 dark:text-charcoal-400 max-w-md font-sans leading-relaxed">
        Click on any piece to inspect details, composition metrics, and custom order guidelines inside our digital lightbox.
      </p>
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {galleryItems.map((item) => (
        <button 
          type="button" 
          class="gallery-item group text-left w-full rounded-3xl overflow-hidden glass-panel border border-gold-400/10 transition-all duration-300 hover:border-gold-400/40 hover:-translate-y-1 hover:shadow-gold-glow flex flex-col cursor-pointer"
          data-id={item.id}
          data-title={item.title}
          data-category={item.category}
          data-desc={item.desc}
          data-image={item.image}
        >
          <!-- Image Container -->
          <div class="h-64 bg-charcoal-200 dark:bg-charcoal-950 flex items-center justify-center relative overflow-hidden w-full">
            <div class="absolute inset-0 bg-gold-400/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10"></div>
            <img 
              src={item.image} 
              alt={item.title} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
              loading="lazy" 
            />
            <span class="absolute top-4 right-4 z-20 px-2.5 py-1 rounded-full bg-charcoal-50/90 dark:bg-charcoal-950/80 border border-gold-400/20 text-[9px] font-bold uppercase tracking-widest text-gold-500 dark:text-gold-300">
              {item.category}
            </span>
          </div>

          <!-- Bottom Info -->
          <div class="p-6 space-y-2 flex-grow bg-white/20 dark:bg-charcoal-950/40">
            <h3 class="font-serif text-lg font-bold group-hover:text-gold-500 transition-colors duration-200">{item.title}</h3>
            <p class="text-xs text-charcoal-600 dark:text-charcoal-400 line-clamp-2 leading-relaxed">{item.desc}</p>
            <span class="text-[10px] font-bold uppercase tracking-wider text-gold-500 group-hover:text-gold-400 flex items-center gap-1.5 pt-2">
              Inspect Piece
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            </span>
          </div>
        </button>
      ))}
    </div>
  </div>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-charcoal-950/90 backdrop-blur-md transition-opacity duration-300" role="dialog" aria-modal="true" aria-labelledby="lightbox-title">
    <div class="absolute inset-0 cursor-pointer" id="lightbox-overlay"></div>
    
    <div class="relative glass-panel rounded-3xl max-w-2xl w-full overflow-hidden z-10 flex flex-col md:flex-row shadow-gold-glow-lg border border-gold-400/20 max-h-[90vh]">
      <!-- Close Button -->
      <button id="lightbox-close" type="button" class="absolute top-4 right-4 p-2 text-charcoal-600 dark:text-charcoal-400 hover:text-charcoal-950 dark:hover:text-white rounded-full bg-charcoal-100/60 dark:bg-charcoal-900/60 focus:outline-none focus:ring-2 focus:ring-gold-400 z-30" aria-label="Close details">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Image Left Display -->
      <div class="h-64 md:h-auto md:w-1/2 bg-charcoal-200 dark:bg-charcoal-950 flex items-center justify-center relative overflow-hidden border-b md:border-b-0 md:border-r border-charcoal-200 dark:border-charcoal-800">
        <img id="lightbox-img" src="" alt="" class="w-full h-full object-cover" />
      </div>

      <!-- Info Right Content -->
      <div class="p-8 md:w-1/2 flex flex-col justify-between overflow-y-auto bg-charcoal-50 dark:bg-charcoal-900">
        <div class="space-y-4">
          <span id="lightbox-category" class="text-[10px] font-bold uppercase tracking-widest text-gold-500">Category</span>
          <h3 id="lightbox-title" class="font-serif text-2xl font-bold">Title</h3>
          <p id="lightbox-desc" class="text-sm text-charcoal-600 dark:text-charcoal-300 leading-relaxed font-sans">Description</p>
        </div>

        <div class="pt-8 border-t border-charcoal-200 dark:border-charcoal-800 space-y-4 mt-6">
          <div class="flex justify-between items-center text-xs text-charcoal-500 dark:text-charcoal-400">
            <span>Purity Standards:</span>
            <span class="text-gold-500 dark:text-gold-400 font-semibold">22K / 18K Hallmarked</span>
          </div>
          <a href="https://wa.me/919635675556" target="_blank" rel="noopener noreferrer" class="block w-full text-center py-3 rounded-full bg-gold-400 hover:bg-gold-300 text-charcoal-950 font-semibold tracking-wider text-xs uppercase transition-colors">
            Inquire About Design
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxOverlay = document.getElementById('lightbox-overlay');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxCategory = document.getElementById('lightbox-category');
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxDesc = document.getElementById('lightbox-desc');
  const galleryItems = document.querySelectorAll('.gallery-item');

  const openLightbox = (el: HTMLElement) => {
    const title = el.getAttribute('data-title');
    const category = el.getAttribute('data-category');
    const desc = el.getAttribute('data-desc');
    const image = el.getAttribute('data-image');

    if (lightbox && lightboxImg && lightboxCategory && lightboxTitle && lightboxDesc && image) {
      // Inject values
      lightboxCategory.textContent = category;
      lightboxTitle.textContent = title;
      lightboxDesc.textContent = desc;
      lightboxImg.src = image;
      lightboxImg.alt = title || 'Jewelry detail';
      
      // Show lightbox
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden'; // Stop page scrolling
      
      // Accessibility focus trap setup
      lightboxClose?.focus();
    }
  };

  const closeLightbox = () => {
    if (lightbox) {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = ''; // Resume page scrolling
    }
  };

  galleryItems.forEach(item => {
    item.addEventListener('click', () => openLightbox(item as HTMLElement));
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightboxOverlay?.addEventListener('click', closeLightbox);

  // Keyboard navigation escape support
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeLightbox();
    }
  });
</script>
