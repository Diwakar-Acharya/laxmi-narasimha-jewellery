---
import { businessConfig } from '../data/config';
---

<section id="about" class="py-24 bg-charcoal-900 relative overflow-hidden">
  <!-- Accent lights -->
  <div class="absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-[40%] right-[-10%] w-[35vw] h-[35vw] rounded-full bg-gold-500/5 blur-[100px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      
      <!-- Graphic/Text Side -->
      <div class="lg:col-span-5 space-y-6">
        <div class="space-y-3">
          <span class="text-xs font-semibold tracking-[0.2em] text-gold-400 uppercase">Our Legacy</span>
          <h2 class="text-3xl sm:text-4xl font-serif font-bold text-white leading-tight">
            Crafting Elegance, <br />
            Preserving Purity
          </h2>
        </div>

        <p class="text-charcoal-300 leading-relaxed font-sans text-sm sm:text-base">
          At Sri Laxmi Narasimha Jewellery, every ornament is a marriage of time-tested heritage and contemporary aesthetics. We sculpt certified gold, diamonds, and precious gemstones with complete transparency.
        </p>

        <!-- Metric highlights -->
        <div class="flex items-center gap-6 pt-4">
          <div class="flex flex-col">
            <span class="text-3xl font-serif font-bold text-gold-400">100%</span>
            <span class="text-xs uppercase tracking-wider text-charcoal-400">BIS Hallmarked</span>
          </div>
          <div class="h-10 w-[1px] bg-charcoal-800"></div>
          <div class="flex flex-col">
            <span class="text-3xl font-serif font-bold text-gold-400">Certified</span>
            <span class="text-xs uppercase tracking-wider text-charcoal-400">Gems & Diamonds</span>
          </div>
        </div>
      </div>

      <!-- Feature Grid Cards Side -->
      <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Card 1 -->
        <div class="glass-panel p-8 rounded-3xl gold-border-hover space-y-4">
          <div class="w-12 h-12 rounded-2xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center text-gold-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-serif font-bold text-white">Absolute Purity</h3>
          <p class="text-xs text-charcoal-400 leading-relaxed">
            Every gram carries official government BIS Hallmark stamps, guaranteeing exact karat purity.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="glass-panel p-8 rounded-3xl gold-border-hover space-y-4">
          <div class="w-12 h-12 rounded-2xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center text-gold-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 9H3m15.364-3.636l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m11.314 11.314l.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z" />
            </svg>
          </div>
          <h3 class="text-lg font-serif font-bold text-white">Bespoke Design</h3>
          <p class="text-xs text-charcoal-400 leading-relaxed">
            Collaborate directly with our master craftsmen to create rings and necklaces customized to your style.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="glass-panel p-8 rounded-3xl gold-border-hover space-y-4">
          <div class="w-12 h-12 rounded-2xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center text-gold-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
          <h3 class="text-lg font-serif font-bold text-white">Transparent Pricing</h3>
          <p class="text-xs text-charcoal-400 leading-relaxed">
            Clear invoices detailing precise metal weights, making charges, and gem valuations.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="glass-panel p-8 rounded-3xl gold-border-hover space-y-4">
          <div class="w-12 h-12 rounded-2xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center text-gold-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-serif font-bold text-white">Exchange Assurances</h3>
          <p class="text-xs text-charcoal-400 leading-relaxed">
            Lifetime buybacks, structural cleaning, and certified polishing for all purchases.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
